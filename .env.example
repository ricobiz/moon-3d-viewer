# OpenRouter API key - get free at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Market data providers (optional - app works without them using synthetic data)
ALPHA_VANTAGE_KEY=demo
TWELVE_DATA_KEY=

# MT5 Bridge URL (only needed for local MT5 connection)
MT5_BRIDGE_URL=http://localhost:8765

NODE_ENV=production
PORT=3000
